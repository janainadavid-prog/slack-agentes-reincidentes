name: Build e Deploy

on:
  push:
    branches: [main]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Injeta token no HTML
        run: |
          sed -i "s/GITHUB_PAT_PLACEHOLDER/${{ secrets.FORM_PAT }}/g" index.html

      - name: Deploy para GitHub Pages
        uses: peaceiris/actions-gh-pages@v3
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
          publish_dir: ./
